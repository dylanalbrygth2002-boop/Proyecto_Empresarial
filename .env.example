# ============================================================================
# DESARROLLO LOCAL
# ============================================================================

# Configuracion de la base de datos PostgreSQL local
# Estas son tus credenciales para desarrollo local
DATABASE_URL="postgresql://postgres:Dai12345@127.0.0.1:5432/sistema_empresarial?schema=public"

# Secreto para firmar tokens JWT
# Genera un valor largo y seguro para produccion
JWT_SECRET="tu-secreto-jwt-super-seguro-cambia-esto"

# Entorno de la aplicacion
NODE_ENV="development"

# ============================================================================
# PRODUCCION (Vercel + Railway)
# ============================================================================
# Copia estas variables en tu panel de Vercel (Settings > Environment Variables)

# URL de PostgreSQL en Railway (obtenla del dashboard de Railway)
# DATABASE_URL="postgresql://usuario:password@host.railway.app:5432/railway?schema=public"

# Mismo JWT_SECRET que uses localmente (debe coincidir para que los tokens funcionen)
# JWT_SECRET="tu-secreto-jwt-super-seguro-cambia-esto"

# NODE_ENV="production"

# ============================================================================
# CAPACITOR / APP MOVIL
# ============================================================================
# URL de tu app desplegada en Vercel. La app movil cargara esta URL.
# Actualiza este valor despues de desplegar en Vercel.
# NEXT_PUBLIC_APP_URL="https://techsolutions-app.vercel.app"