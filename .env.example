# Configuracion de la base de datos PostgreSQL en Railway
# Reemplaza estos valores con tus credenciales reales de Railway
DATABASE_URL="postgresql://usuario:password@host:puerto/nombre_base_datos?schema=public"

# Secreto para firmar tokens JWT
# Genera un valor largo y seguro para produccion
JWT_SECRET="tu-secreto-jwt-super-seguro-cambia-esto"

# Entorno de la aplicacion
NODE_ENV="development"